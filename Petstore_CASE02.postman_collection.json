			"item": [
				{
					"name": "TC-P01: Create New Pet (POST /pet)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"// Assertion: Status code harus 200",
									"pm.test('TC-P01: Status code is 200', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"// Assertion: Response body memiliki field id dan name",
									"pm.test('TC-P01: Response body has id and name', function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData).to.have.property('id');",
									"    pm.expect(jsonData).to.have.property('name');",
									"    pm.expect(jsonData.name).to.eql('DoggyTest');",
									"    pm.expect(jsonData.status).to.eql('available');",
									"});",
									"",
									"// Chaining: Simpan petId untuk request berikutnya",
									"var jsonData = pm.response.json();",
									"pm.collectionVariables.set('petId', jsonData.id);",
									"console.log('Pet ID saved: ' + jsonData.id);"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"id\": 99881,\n  \"category\": {\n    \"id\": 1,\n    \"name\": \"Dogs\"\n  },\n  \"name\": \"DoggyTest\",\n  \"photoUrls\": [\n    \"https://example.com/photo.jpg\"\n  ],\n  \"tags\": [\n    {\n      \"id\": 1,\n      \"name\": \"test-tag\"\n    }\n  ],\n  \"status\": \"available\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/pet",
							"host": ["{{baseUrl}}"],
							"path": ["pet"]
						}
					}
				},
